# Copie este arquivo para ".env" e preencha com as credenciais do seu projeto Firebase
# (Console do Firebase > Configurações do projeto > Seus apps > SDK setup and configuration).
# Sem essas variáveis o app sobe normalmente, mas qualquer chamada a src/firebase/* falha
# com um erro explicativo (ver src/firebase/config.ts).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
